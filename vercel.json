{
  "name": "jvto-unified-dashboard",
  "version": 2,
  "public": true,
  "buildCommand": "npm run build",
  "framework": "nextjs",
  "env": {
    "DB_HOST": "@db_host",
    "DB_PORT": "@db_port",
    "DB_NAME": "@db_name",
    "DB_USER": "@db_user",
    "DB_PASSWORD": "@db_password",
    "BACKOFFICE_URL": "https://new-backoffice.javavolcano-touroperator.com",
    "NODE_ENV": "production"
  },
  "regions": ["sin1", "icn1", "iad1"],
  "functions": {
    "api/**": {
      "maxDuration": 60
    }
  }
}
